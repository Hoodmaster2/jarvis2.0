# JARVIS Configuration
# Copy this file to .env and fill in your values

# Ollama
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen3

# Web Search (optional - pick one)
SEARCH_API_KEY=
SEARCH_ENGINE=duckduckgo  # Options: duckduckgo, google, bing, serpapi

# Weather (optional)
WEATHER_API_KEY=

# GitHub (optional)
GITHUB_TOKEN=

# Voice
STT_ENGINE=whisper    # whisper, windows
TTS_ENGINE=piper      # piper, windows, elevenlabs

# Memory
MEMORY_ENABLED=true
MEMORY_PATH=./data/memory.db

# Logging
LOG_LEVEL=INFO
LOG_FILE=./data/jarvis.log

# Security
PERMISSION_MODE=ask  # ask, auto, strict

# API (optional)
JARVIS_API_PORT=8765
JARVIS_API_HOST=127.0.0.1
