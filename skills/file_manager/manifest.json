{
  "name": "file_manager",
  "version": "1.0.0",
  "description": "Browse, read, create, edit, move, search files on the local filesystem",
  "author": "JARVIS",
  "permissions": ["safe", "medium"],
  "commands": [
    {
      "name": "list",
      "description": "List files and directories in a path",
      "parameters": {
        "path": { "type": "string", "description": "Directory path to list" }
      },
      "required": ["path"]
    },
    {
      "name": "read",
      "description": "Read contents of a text file",
      "parameters": {
        "path": { "type": "string", "description": "File path to read" }
      },
      "required": ["path"]
    },
    {
      "name": "create",
      "description": "Create a new file with content",
      "parameters": {
        "path": { "type": "string", "description": "File path to create" },
        "content": { "type": "string", "description": "File content" }
      },
      "required": ["path", "content"]
    },
    {
      "name": "edit",
      "description": "Edit an existing file (append or replace)",
      "parameters": {
        "path": { "type": "string", "description": "File path to edit" },
        "content": { "type": "string", "description": "New content" },
        "mode": { "type": "string", "description": "replace or append", "enum": ["replace", "append"] }
      },
      "required": ["path", "content"]
    },
    {
      "name": "search",
      "description": "Search for files by name or pattern",
      "parameters": {
        "pattern": { "type": "string", "description": "Search pattern (glob)" },
        "path": { "type": "string", "description": "Root directory to search" }
      },
      "required": ["pattern"]
    },
    {
      "name": "move",
      "description": "Move or rename a file",
      "parameters": {
        "source": { "type": "string", "description": "Source path" },
        "destination": { "type": "string", "description": "Destination path" }
      },
      "required": ["source", "destination"]
    },
    {
      "name": "delete",
      "description": "Delete a file (requires high permission)",
      "parameters": {
        "path": { "type": "string", "description": "File path to delete" }
      },
      "required": ["path"],
      "risk_level": "critical"
    }
  ]
}
